# Google Sheets CMS — replaces all SANITY_* variables
GOOGLE_SHEET_ID=                        # The long ID from the Sheet URL
                                        # e.g. 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_SERVICE_ACCOUNT_EMAIL=           # e.g. photoframes-vf@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=                     # Multi-line key — wrap in quotes in .env.local

# WhatsApp — synced from Site Settings tab of Google Sheet, set during build or via Vercel env
NEXT_PUBLIC_WHATSAPP_NUMBER=            # Format: +234XXXXXXXXXX — no spaces

# PostgreSQL (Supabase or Railway) — optional, leave blank if not using
DATABASE_URL=                           # postgres://user:pass@host:5432/dbname

# Vercel (auto-set during deployment)
VERCEL_URL=
