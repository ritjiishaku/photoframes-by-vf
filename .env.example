# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=                             # Server-only — never exposed to client

# WhatsApp — synced from Sanity siteSettings, set during build or via Vercel env
NEXT_PUBLIC_WHATSAPP_NUMBER=                  # Format: +234XXXXXXXXXX — no spaces

# PostgreSQL (Supabase or Railway)
DATABASE_URL=                                 # postgres://user:pass@host:5432/dbname

# Sanity Webhook (optional — if not set, webhook signature validation is skipped)
SANITY_WEBHOOK_SECRET=

# Vercel (auto-set during deployment)
VERCEL_URL=
